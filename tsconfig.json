{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Preserve",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "noUncheckedIndexedAccess": true,
        "verbatimModuleSyntax": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": [
        "src/**/*",
        "tests/**/*",
        "vite.config.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}