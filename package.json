{
  "name": "@plantae-tech/inkpresser",
  "version": "1.2.4",
  "description": "Native Node.js library for managing printers and raw printing, including ESC/POS, thermal, and dot-matrix, in Node.js and Electron.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**/*",
    "native/**/*",
    "prebuilds/**/*",
    "binding.gyp",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/plantae-technologies/inkpresser"
  },
  "keywords": [
    "printer",
    "printing",
    "escpos",
    "esc-pos",
    "thermal-printer",
    "dot-matrix",
    "raw-printing",
    "cups",
    "electron",
    "node-addon",
    "napi",
    "cross-platform"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format:native": "clang-format -i native/src/*.cpp native/src/*.h",
    "build:native": "node-gyp configure build",
    "build:ts": "vite build",
    "build": "npm run build:native && npm run build:ts",
    "clean": "rmdir /s /q build dist || rm -rf build dist",
    "rebuild": "npm run clean && npm run build",
    "test": "vitest run tests/unit",
    "test:coverage": "vitest run tests/unit --coverage",
    "test:integration": "vitest run tests/integration",
    "test:print": "vite-node tests/manual/test-print.ts",
    "install": "node-gyp-build",
    "prepare": "vite build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "clang-format": "^1.8.0",
    "iconv-lite": "^0.7.2",
    "node-gyp": "^12.2.0",
    "prebuildify": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-node": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "node-addon-api": "^8.3.0",
    "node-gyp-build": "^4.8.4"
  },
  "license": "MIT"
}
